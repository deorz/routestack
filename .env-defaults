# App
ROUTESTACK_APP_NAME=RouteStack

# HTTP server
ROUTESTACK_SERVER_HOST=127.0.0.1
ROUTESTACK_SERVER_PORT=8000

# REST API
ROUTESTACK_API_ROOT_PREFIX=
ROUTESTACK_API_DOCS_ENABLED=true

# Database
ROUTESTACK_DATABASE_URL=sqlite:///./routestack.db

# Security
# Override this for shared deployments.
ROUTESTACK_SECURITY_SECRET_KEY=change-me-in-production

# Admin session
ROUTESTACK_ADMIN_SESSION_TTL_SECONDS=43200
ROUTESTACK_ADMIN_SESSION_COOKIE_NAME=routestack_admin_session
